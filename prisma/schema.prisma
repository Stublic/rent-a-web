// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  emailVerified    Boolean
  image            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Custom fields for Rent a webica
  subscriptionStatus String?  // active, canceled, etc.
  stripeCustomerId   String?  @unique
  planName           String?  // Starter, Advanced, Web Shop Start
  phoneNumber        String?
  role               String   @default("USER")  // USER, ADMIN
  lastDripEmailSent  Int      @default(0)       // Track drip campaign step (0, 3, 7, 14)

  // Account-level token system (shared across all projects)
  editorTokens       Int      @default(0)       // Remaining AI edit tokens
  editorTokensUsed   Int      @default(0)       // Total tokens consumed (analytics)

  // Referral system
  referralCode       String?  @unique           // Unique 6-char code for sharing
  referredById       String?                    // Who referred this user
  referredBy         User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referrals          User[]   @relation("UserReferrals")
  referralsCount     Int      @default(0)       // Number of successful referrals

  sessions         Session[]
  accounts         Account[]
  projects         Project[]
  invoices         Invoice[]
  media            Media[]
  feedbacks        Feedback[]
  tickets          Ticket[]
  bugReports       BugReport[]

  @@map("user")
}

model Project {
  id                   String   @id @default(cuid())
  name                 String
  domain               String?
  subdomain            String?  @unique   // e.g. "moj-projekt" → moj-projekt.webica.hr
  customDomain         String?  @unique   // e.g. "mojadomela.hr"
  contactEmail         String?            // Email for contact form inquiries (overrides user.email)
  publishedAt          DateTime?          // When the site was published
  status               String   @default("DRAFT") // DRAFT, SUBMITTED, GENERATED, PUBLISHED, LIVE
  planName             String
  stripeSubscriptionId String?  @unique
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Content Generation Fields
  contentData          Json?    // Stores raw form data
  generatedHtml        String?  @db.Text // Large text field for AI output (Starter) or built HTML (Advanced)
  reactFiles           Json?    // Advanced: { "pages/Home.jsx": "...", ... } AI-generated React files
  reactConfig          Json?    // Advanced: { primaryColor, font, pages[], ... } template config
  aiVersion            Int      @default(1)
  hasGenerated         Boolean  @default(false) // Track if website has been generated
  
  // Editor Fields
  editHistory          Json[]   @default([])  // Array of edit events for undo
  lastEditedAt         DateTime?
  
  // Editor Token System
  editorTokens         Int      @default(500)  // Remaining tokens for AI edits (500 initial)
  editorTokensUsed     Int      @default(0)    // Total tokens consumed

  // Google Ads
  googleAdsCampaign    GoogleAdsCampaign?

  // Blog
  blogPosts            BlogPost[]
  blogCategories       BlogCategory[]
  contactSubmissions   ContactSubmission[]
  blogPostsUsedThisMonth Int    @default(0)    // Monthly AI blog generation counter
  blogPostsResetAt     DateTime?               // When the monthly counter was last reset

  // Cancellation / Grace Period
  cancelledAt          DateTime?
  deletionReminders    String   @default("") // Comma-separated reminder days sent, e.g. "30,60,83"

  // Buyout
  buyoutStatus         String   @default("NONE")  // NONE, MAINTAINED, EXPORTED_LOCKED
  exportExpiresAt      DateTime?                   // Option 2: 90-day deletion deadline

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("project")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model StripeSubscription {
  id               String   @id @default(cuid())
  email            String   @unique
  stripeCustomerId String   @unique
  planName         String
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("stripe_subscription")
}
model Invoice {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId        String?
  invoiceNumber    String   @unique
  amount           Float
  description      String
  pdfUrl           String?
  stripeSessionId  String?  @unique
  type             String   // SUBSCRIPTION, TOKEN_PURCHASE
  status           String   @default("PAID") // PAID, PENDING, FAILED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("invoice")
}

model Media {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  filename  String
  url       String
  size      Int
  type      String   // image/png, video/mp4, application/pdf, etc.
  createdAt DateTime @default(now())

  @@map("media")
}

model BlogPost {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  slug            String
  excerpt         String?
  content         String        @db.Text
  coverImage      String?
  categoryId      String?
  category        BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags            String?       @db.Text  // Comma-separated tags
  status          String        @default("DRAFT") // DRAFT, PUBLISHED
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([projectId, slug])
  @@map("blog_post")
}

model BlogCategory {
  id        String     @id @default(cuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  posts     BlogPost[]
  createdAt DateTime   @default(now())

  @@unique([projectId, slug])
  @@map("blog_category")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_submission")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   String   @db.Text  // JSON stringified answers
  createdAt DateTime @default(now())

  @@map("feedback")
}

model GeminiUsage {
  id           String   @id @default(cuid())
  type         String   // e.g. "generate_page", "generate_image", "edit_page", "blog_post"
  model        String   // "gemini-3-flash-preview", "gemini-3-pro-image-preview", etc.
  tokensInput  Int      @default(0)
  tokensOutput Int      @default(0)
  cost         Float    @default(0) // Estimated cost in USD or EUR
  createdAt    DateTime @default(now())

  @@map("gemini_usage")
}

model DesignReference {
  id          String   @id @default(cuid())
  imageUrl    String   // Vercel Blob URL
  sourceUrl   String?  // Original website URL
  tags        String[] // e.g. ["restoran", "moderna", "tamna"]
  industry    String?  // e.g. "Ugostiteljstvo"
  style       String?  // e.g. "minimalist", "bold", "elegant"
  title       String?  // Admin label
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("design_reference")
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

model Ticket {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  subject   String
  status    String          @default("OPEN")      // OPEN, RESOLVED, ESCALATED
  type      String          @default("TECHNICAL")  // TECHNICAL, BILLING
  messages  TicketMessage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("ticket")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  role      String   // USER, AI, ADMIN
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@map("ticket_message")
}

model GoogleAdsCampaign {
  id                     String   @id @default(cuid())
  projectId              String   @unique
  project                Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status                 String   @default("PENDING") // PENDING, AWAITING_ADMIN, ACTIVE
  stripeSubscriptionId   String?  @unique             // Google Ads Boost subscription
  generatedHeadlines     Json?    // 15 short headlines (30 chars each)
  generatedLongHeadlines Json?    // 4 long headlines (90 chars each)
  generatedDescriptions  Json?    // 4 descriptions (90 chars each)
  generatedKeywords      Json?    // 50 high-intent keywords
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("google_ads_campaign")
}

model BugReport {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String   @db.Text
  severity      String   @default("medium")   // low, medium, high, critical
  page          String?                        // URL/page where bug occurred
  screenshotUrl String?                        // Vercel Blob URL for screenshot
  status        String   @default("OPEN")      // OPEN, IN_PROGRESS, RESOLVED
  createdAt     DateTime @default(now())

  @@map("bug_report")
}
